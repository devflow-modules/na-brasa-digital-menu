# Database
# Local: point to your Postgres. Production (Vercel): use Neon/Supabase connection string with SSL.
DATABASE_URL="postgresql://user:password@localhost:5432/na_brasa?schema=public"

# Admin (placeholders for local only — never commit real credentials)
# Production: use a strong unique password (min 8; prefer longer)
# Production: use a long random JWT secret (min 16; prefer 32+)
ADMIN_EMAIL="admin@nabrasa.local"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_JWT_SECRET="change-this-secret"
ADMIN_SESSION_COOKIE="na-brasa-admin-session"

# App
# Production: set to the final HTTPS URL (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Must match Store.slug in the database (seed uses na-brasa)
NEXT_PUBLIC_STORE_SLUG="na-brasa"

# Runtime (usually set by Next.js / Vercel; Secure cookies when NODE_ENV=production)
# NODE_ENV=development

# Notes:
# - prisma/seed.ts uses WhatsApp placeholder 5513999999999 (not a real number).
# - Do not commit a real .env file.
# - Production deploy: docs/deployment.md and docs/production-checklist.md
# - E2E CI uses ephemeral Postgres — never production DATABASE_URL
