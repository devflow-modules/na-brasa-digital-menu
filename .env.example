# Database
# Local: point to your Postgres. Production (Vercel): use Neon/Supabase connection string with SSL.
DATABASE_URL="postgresql://user:password@localhost:5432/na_brasa?schema=public"

# Admin session (technical — required for JWT cookie)
# Production: long random JWT secret (min 16; prefer 32+ chars)
ADMIN_JWT_SECRET="change-this-secret"
ADMIN_SESSION_COOKIE="na-brasa-admin-session"

# Master / first admin bootstrap (seed only — creates User with role MASTER)
# Required for a usable /admin login on a fresh database: migrate + seed with these set.
# Production: set all three with a strong unique password. No hardcoded defaults.
# See docs/adr/0002-database-backed-multi-admin-and-master-panel.md
MASTER_ADMIN_NAME=
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=

# Deprecated — NOT used by /admin login runtime anymore (auth is User in the database).
# May still appear in old deployments; safe to remove from Vercel after cutover.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# App
# Production: set to the final HTTPS URL (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Must match Store.slug in the database (seed uses na-brasa)
NEXT_PUBLIC_STORE_SLUG="na-brasa"

# Runtime (usually set by Next.js / Vercel; Secure cookies when NODE_ENV=production)
# NODE_ENV=development

# iFood Merchant API — TEST APP ONLY (#120). Never commit real secrets.
# Use the auto-created “… Teste (C)” credentials. Do not put secrets in the DB.
# IFOOD_CLIENT_ID=
# IFOOD_CLIENT_SECRET=
# IFOOD_TEST_MERCHANT_ID=
# Optional override (defaults to NEXT_PUBLIC_STORE_SLUG / na-brasa):
# IFOOD_TEST_STORE_SLUG=na-brasa
# One-shot poller: pnpm ifood:poll -- --once

# Notes:
# - /admin/login authenticates against User.email + User.passwordHash (bcrypt).
# - MASTER can access /admin temporarily until /master exists (transitional).
# - prisma/seed.ts uses WhatsApp placeholder 5513999999999 only when first creating Store na-brasa.
# - Re-running seed does not overwrite an existing Store's WhatsApp or other operational fields.
# - Do not commit a real .env file.
# - Production deploy: docs/deployment.md and docs/production-checklist.md
# - E2E CI uses ephemeral Postgres — never production DATABASE_URL
