# Database
# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/na_brasa?schema=public"

# Admin (placeholder credentials for local setup only — change before production)
# ADMIN_PASSWORD: min 8 characters (use a strong password in production)
# ADMIN_JWT_SECRET: min 16 characters (use a long random secret in production)
ADMIN_EMAIL="admin@nabrasa.local"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_JWT_SECRET="change-this-secret"
ADMIN_SESSION_COOKIE="na-brasa-admin-session"

# App
# NEXT_PUBLIC_APP_URL: public base URL (https://... in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_SLUG="na-brasa"

# Runtime (usually set by Next.js / Vercel; cookie Secure is enabled when NODE_ENV=production)
# NODE_ENV=development

# Note: prisma/seed.ts uses WhatsApp placeholder 5513999999999 (not a real number).
# Do not commit a real .env file. See docs/deployment.md for production setup.
