generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  DEBIT_CARD
  CREDIT_CARD
}

enum OrderSource {
  DIRECT
  IFOOD
  OTHER
  COUNTER
}

/// Platform and store operator roles (ADR 0002).
/// MASTER: DevFlow Labs / platform — storeId may be null.
/// Store roles (STORE_OWNER, MANAGER, OPERATOR, KITCHEN): should be bound to a Store
/// (storeId required in future auth/admin PRs; not enforced by DB constraint in this PR).
enum UserRole {
  MASTER
  STORE_OWNER
  MANAGER
  OPERATOR
  KITCHEN
}

/// Closed allowlist for pilot funnel instrumentation (#103).
/// Reserved payment_* names for InfiniteTap are documented, not emitted here.
enum FunnelEventName {
  menu_viewed
  product_added
  checkout_started
  order_created
  whatsapp_handoff_started
  order_confirmed
  order_completed
  order_cancelled
}

model Store {
  id                       String     @id @default(cuid())
  name                     String
  slug                     String     @unique
  description              String?
  whatsapp                 String
  address                  String?
  openingHours             String?
  isOpen                   Boolean    @default(true)
  pickupEnabled            Boolean    @default(true)
  deliveryEnabled          Boolean    @default(false)
  deliveryFeeCents         Int        @default(0)
  minimumOrderAmountCents  Int        @default(0)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  categories        Category[]
  products          Product[]
  addons            Addon[]
  addonGroups       AddonGroup[]
  orders            Order[]
  orderPayments     OrderPayment[]
  users             User[]
  funnelEvents      FunnelEvent[]
  ifoodConnections  IfoodConnection[]
  ifoodEvents       IfoodEvent[]
  ifoodOrders       IfoodOrder[]
}

/// Processing state for durable iFood inbox events (#120).
enum IfoodEventProcessingStatus {
  /// Persisted but not handled (unknown codes stay here).
  PENDING
  /// Handled (order snapshot refreshed when applicable).
  PROCESSED
  /// Persist ok; later handling failed (still eligible for ACK).
  FAILED
}

/// Store ↔ iFood merchant binding. Credentials stay in env, never here.
model IfoodConnection {
  id           String    @id @default(cuid())
  storeId      String
  merchantId   String
  isActive     Boolean   @default(true)
  /// Optimistic poller lock — stale locks may be stolen after TTL.
  pollLockedAt DateTime?
  pollLockedBy String?
  lastPolledAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store  Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  events IfoodEvent[]
  orders IfoodOrder[]

  @@unique([merchantId])
  @@unique([storeId, merchantId])
  @@index([storeId, isActive])
}

/// Append-only iFood events inbox. ACK only after durable persist.
model IfoodEvent {
  id               String                      @id @default(cuid())
  connectionId     String
  storeId          String
  externalEventId  String
  code             String?
  fullCode         String?
  externalOrderId  String?
  merchantId       String
  /// Raw event JSON (no credentials).
  payload          Json
  receivedAt       DateTime                    @default(now())
  acknowledgedAt   DateTime?
  processingStatus IfoodEventProcessingStatus  @default(PENDING)
  processedAt      DateTime?
  processingError  String?

  connection IfoodConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  store      Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([connectionId, externalEventId])
  @@index([connectionId, receivedAt])
  @@index([storeId, receivedAt])
  @@index([externalOrderId])
  @@index([processingStatus])
}

/// External order snapshot keyed by iFood order id (not operational Order).
model IfoodOrder {
  id                String    @id @default(cuid())
  connectionId      String
  storeId           String
  externalOrderId   String
  displayId         String?
  /// Latest event fullCode by event time — never by poll array order.
  lastEventFullCode String?
  lastEventAt       DateTime?
  /// Tie-break when lastEventAt collides (lexicographic external event id).
  lastExternalEventId String?
  snapshot            Json?
  snapshotFetchedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  connection IfoodConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  store      Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([connectionId, externalOrderId])
  @@index([storeId, updatedAt])
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  storeId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store             Store?         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdOrders     Order[]        @relation("OrderCreatedByUser")
  createdPayments   OrderPayment[] @relation("OrderPaymentCreatedByUser")

  @@index([storeId])
  @@index([role])
  @@index([isActive])
}

model Category {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([storeId, sortOrder])
  @@index([storeId, active])
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  categoryId  String
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  active      Boolean  @default(true)
  available   Boolean  @default(true)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productAddons ProductAddon[]
  addonGroups   AddonGroup[]
  orderItems    OrderItem[]

  @@index([storeId, categoryId])
  @@index([storeId, active])
  @@index([storeId, sortOrder])
}

model Addon {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  priceCents  Int
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productAddons      ProductAddon[]
  groupOptions       AddonGroupOption[]
  orderItemAddons    OrderItemAddon[]

  @@index([storeId, active])
  @@index([storeId, sortOrder])
}

model ProductAddon {
  productId String
  addonId   String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addon   Addon   @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@id([productId, addonId])
  @@index([addonId])
}

/// Product-scoped selection group (optional/required/exclusive addons).
model AddonGroup {
  id           String   @id @default(cuid())
  storeId      String
  productId    String
  name         String
  description  String?
  minSelection Int      @default(0)
  maxSelection Int
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store   Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  options AddonGroupOption[]

  @@index([storeId, productId, active])
  @@index([productId, sortOrder])
}

model AddonGroupOption {
  groupId   String
  addonId   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  group AddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addon Addon      @relation(fields: [addonId], references: [id], onDelete: Restrict)

  @@id([groupId, addonId])
  @@index([addonId])
}

model Order {
  id                String         @id @default(cuid())
  storeId           String
  code              String         @unique
  customerName      String
  /// Optional on persisted domain: COUNTER may omit phone. DIRECT still requires it in public create.
  customerPhone     String?
  deliveryType      DeliveryType
  deliveryAddress   String?
  /// Optional on persisted domain: COUNTER opens before payment. DIRECT still requires it in public create.
  paymentMethod     PaymentMethod?
  changeForCents    Int?
  notes             String?
  subtotalCents     Int
  deliveryFeeCents  Int            @default(0)
  totalCents        Int
  status            OrderStatus    @default(PENDING)
  source            OrderSource    @default(DIRECT)
  whatsappMessage   String?
  /// Set when payment is confirmed (future COUNTER checkout). Existing rows stay null.
  paidAt            DateTime?
  /// Operator who opened the order (COUNTER). Never accepted from untrusted client payload.
  createdByUserId   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  store         Store          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdByUser User?          @relation("OrderCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  payments      OrderPayment[]
  funnelEvents  FunnelEvent[]

  @@unique([id, storeId])
  @@index([storeId, createdAt])
  @@index([storeId, status])
  @@index([source])
}

/// COUNTER tender lines. One row per method per order.
/// amountCents applies to total; tenderedCents/changeCents only for CASH.
model OrderPayment {
  id              String        @id @default(cuid())
  storeId         String
  orderId         String
  method          PaymentMethod
  amountCents     Int
  tenderedCents   Int?
  changeCents     Int?
  createdByUserId String?
  createdAt       DateTime      @default(now())

  store         Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  order         Order  @relation(fields: [orderId, storeId], references: [id, storeId], onDelete: Cascade)
  createdByUser User?  @relation("OrderPaymentCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([orderId, method])
  @@index([storeId, createdAt])
  @@index([orderId])
}

/// Append-only funnel telemetry. No PII. Server sets occurredAt.
model FunnelEvent {
  id               String          @id @default(cuid())
  storeId          String
  name             FunnelEventName
  /// Unique per store — never global. Callers must encode occurrence for repeatable events.
  dedupeKey        String
  /// Always assigned by the server at record time.
  occurredAt       DateTime
  /// Optional client clock — auxiliary only; never trusted as occurredAt.
  clientOccurredAt DateTime?
  sessionId        String?
  orderId          String?
  productId        String?
  source           OrderSource?
  quantity         Int?
  createdAt        DateTime        @default(now())

  store Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([storeId, dedupeKey])
  @@index([storeId, name, occurredAt])
  @@index([storeId, occurredAt])
  @@index([orderId])
}

model OrderItem {
  id                         String   @id @default(cuid())
  orderId                    String
  productId                  String?
  productNameSnapshot        String
  productDescriptionSnapshot String?
  quantity                   Int
  unitPriceCents             Int
  notes                      String?
  totalCents                 Int
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  order  Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  addons OrderItemAddon[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemAddon {
  id               String   @id @default(cuid())
  orderItemId      String
  addonId          String?
  addonNameSnapshot String
  addonPriceCents  Int
  createdAt        DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addon     Addon?    @relation(fields: [addonId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([addonId])
}
