generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  DEBIT_CARD
  CREDIT_CARD
}

enum OrderSource {
  DIRECT
  IFOOD
  OTHER
  COUNTER
}

/// Platform and store operator roles (ADR 0002).
/// MASTER: DevFlow Labs / platform — storeId may be null.
/// Store roles (STORE_OWNER, MANAGER, OPERATOR, KITCHEN): should be bound to a Store
/// (storeId required in future auth/admin PRs; not enforced by DB constraint in this PR).
enum UserRole {
  MASTER
  STORE_OWNER
  MANAGER
  OPERATOR
  KITCHEN
}

model Store {
  id                       String     @id @default(cuid())
  name                     String
  slug                     String     @unique
  description              String?
  whatsapp                 String
  address                  String?
  openingHours             String?
  isOpen                   Boolean    @default(true)
  pickupEnabled            Boolean    @default(true)
  deliveryEnabled          Boolean    @default(false)
  deliveryFeeCents         Int        @default(0)
  minimumOrderAmountCents  Int        @default(0)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  categories  Category[]
  products    Product[]
  addons      Addon[]
  addonGroups AddonGroup[]
  orders      Order[]
  users       User[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  storeId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store             Store?  @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdOrders     Order[] @relation("OrderCreatedByUser")

  @@index([storeId])
  @@index([role])
  @@index([isActive])
}

model Category {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([storeId, sortOrder])
  @@index([storeId, active])
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  categoryId  String
  name        String
  description String?
  priceCents  Int
  imageUrl    String?
  active      Boolean  @default(true)
  available   Boolean  @default(true)
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productAddons ProductAddon[]
  addonGroups   AddonGroup[]
  orderItems    OrderItem[]

  @@index([storeId, categoryId])
  @@index([storeId, active])
  @@index([storeId, sortOrder])
}

model Addon {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  priceCents  Int
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productAddons      ProductAddon[]
  groupOptions       AddonGroupOption[]
  orderItemAddons    OrderItemAddon[]

  @@index([storeId, active])
  @@index([storeId, sortOrder])
}

model ProductAddon {
  productId String
  addonId   String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addon   Addon   @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@id([productId, addonId])
  @@index([addonId])
}

/// Product-scoped selection group (optional/required/exclusive addons).
model AddonGroup {
  id           String   @id @default(cuid())
  storeId      String
  productId    String
  name         String
  description  String?
  minSelection Int      @default(0)
  maxSelection Int
  active       Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store   Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  options AddonGroupOption[]

  @@index([storeId, productId, active])
  @@index([productId, sortOrder])
}

model AddonGroupOption {
  groupId   String
  addonId   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  group AddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addon Addon      @relation(fields: [addonId], references: [id], onDelete: Restrict)

  @@id([groupId, addonId])
  @@index([addonId])
}

model Order {
  id                String         @id @default(cuid())
  storeId           String
  code              String         @unique
  customerName      String
  /// Optional on persisted domain: COUNTER may omit phone. DIRECT still requires it in public create.
  customerPhone     String?
  deliveryType      DeliveryType
  deliveryAddress   String?
  /// Optional on persisted domain: COUNTER opens before payment. DIRECT still requires it in public create.
  paymentMethod     PaymentMethod?
  changeForCents    Int?
  notes             String?
  subtotalCents     Int
  deliveryFeeCents  Int            @default(0)
  totalCents        Int
  status            OrderStatus    @default(PENDING)
  source            OrderSource    @default(DIRECT)
  whatsappMessage   String?
  /// Set when payment is confirmed (future COUNTER checkout). Existing rows stay null.
  paidAt            DateTime?
  /// Operator who opened the order (COUNTER). Never accepted from untrusted client payload.
  createdByUserId   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  store         Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdByUser User?       @relation("OrderCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items         OrderItem[]

  @@index([storeId, createdAt])
  @@index([storeId, status])
  @@index([source])
}

model OrderItem {
  id                         String   @id @default(cuid())
  orderId                    String
  productId                  String?
  productNameSnapshot        String
  productDescriptionSnapshot String?
  quantity                   Int
  unitPriceCents             Int
  notes                      String?
  totalCents                 Int
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  order  Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  addons OrderItemAddon[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemAddon {
  id               String   @id @default(cuid())
  orderItemId      String
  addonId          String?
  addonNameSnapshot String
  addonPriceCents  Int
  createdAt        DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addon     Addon?    @relation(fields: [addonId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([addonId])
}
